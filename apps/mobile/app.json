{
  "expo": {
    "name": "mobile",
    "slug": "hi-money",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "mobile",
      "budgetcoach"
    ],
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash/splash-01.png",
      "resizeMode": "contain",
      "backgroundColor": "#2EE67A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kwayne.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-video",
      [
        "expo-notifications",
        {
          "sounds": [],
          "enableBackgroundRemoteNotifications": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a27b1ab4-a2b4-42b8-a842-beecebc38898"
      }
    },
    "owner": "kwayne"
  }
}
